[production]
name=production
runtime=host
toolchain=default
config-opts=-Dprofile=production
run-opts=
prefix=$HOME/.cache/gnome-builder/install/HostsManager/host
app-id=org.gnome.gitlab.spo-ijaz.hostsmanager
postbuild=
prebuild=
run-command=$HOME/.cache/gnome-builder/install/HostsManager/host/bin/org.gnome.gitlab.spo-ijaz.hostsmanager.app
default=true


[development]
name=development
runtime=host
toolchain=default
config-opts=-Dprofile=development
run-opts=
prefix=$HOME/.cache/gnome-builder/install/HostsManager/host
app-id=org.gnome.gitlab.spo-ijaz.hostsmanager
postbuild=
prebuild=
run-command=$HOME/.cache/gnome-builder/install/HostsManager/host/bin/org.gnome.gitlab.spo-ijaz.hostsmanager.app
default=true
