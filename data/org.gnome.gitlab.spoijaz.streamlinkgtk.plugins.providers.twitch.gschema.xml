<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="streamlink-gtk">
  <schema id="org.gnome.gitlab.spoijaz.streamlinkgtk.plugins.providers.twitch"
    path="/org/gnome/gitlab/spoijaz/streamlinkgtk/plugins/providers/twitch/">
    <key name="website-oauth" type="s">
      <default>""</default>
      <summary>OAuth token from Twitch website.</summary>
      <description>Twitch session ID</description>
    </key>
    <key name="enable-notifications" type="b">
      <default>false</default>
      <summary>If activated, it will display a notifiation when a stream start.</summary>
      <description></description>
    </key>
    <key name="refresh-interval" type="u">
      <default>5</default>
      <summary>Refresh interval (in minutes)</summary>
      <description></description>
    </key>
    <key name="last-async-execution-time" type="s">
      <default>""</default>
      <summary>Last time we run the async tasks.</summary>
      <description>.</description>
    </key>
    <key name="last-number-of-live-streams" type="u">
      <default>0</default>
      <summary>Store the number of live stream</summary>
      <description></description>
    </key>
  </schema>
</schemalist>
