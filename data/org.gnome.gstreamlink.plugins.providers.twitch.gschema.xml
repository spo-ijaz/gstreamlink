<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="gstreamlink">
  <schema id="org.gnome.gstreamlink.plugins.providers.twitch"
    path="/org/gnome/gstreamlink/plugins/providers/twitch/">
    <key name="website-oauth" type="s">
      <default>""</default>
      <summary>OAuth token from Twitch website.</summary>
      <description>Twitch session ID</description>
    </key>
    <key name="enable-notifications" type="b">
      <default>false</default>
      <summary>If activated, it will display a notifiation when a stream start.</summary>
      <description></description>
    </key>
    <key name="refresh-interval" type="u">
      <default>5</default>
      <summary>Refresh interval (in minutes)</summary>
      <description></description>
    </key>
    <key name="last-async-execution-time" type="s">
      <default>""</default>
      <summary>Last time we ran the async tasks.</summary>
      <description>.</description>
    </key>
    <key name="last-live-stream-ids" type="as">
      <default>[]</default>
      <summary>Store the live streams.</summary>
      <description></description>
    </key>
  </schema>
</schemalist>
