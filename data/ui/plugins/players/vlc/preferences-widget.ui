<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.1 -->
<interface>
  <!-- interface-name preferences-widget.ui -->
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.6"/>
  <template class="StreamlinkGtkWidgetsPlayersVlcPreferencesGroup" parent="AdwPreferencesGroup">
    <property name="description">All options for VLC player</property>
    <property name="title">VLC preferences</property>
    <child>
      <object class="GtkListBox">
        <child>
          <object class="AdwSwitchRow" id="switch_enable_minimal_ui">
            <property name="subtitle">If activated, will hide VLC controls.</property>
            <property name="title">Minimal layout</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
