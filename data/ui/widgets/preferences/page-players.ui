<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.90.4 -->
<interface domain="org.gnome.gitlab.spoijaz.streamlinkgtk">
  <!-- interface-name preferences-interface.ui -->
  <requires lib="libadwaita" version="1.5"/>
  <requires lib="gio" version="2.44"/>
  <template class="StreamlinkGtkPreferencesPagePlayers" parent="AdwPreferencesPage">
    <property name="icon-name">multimedia-player-symbolic</property>
    <property name="name">page_player</property>
    <property name="title" translatable="yes">Players</property>
    <child>
      <object class="AdwPreferencesGroup">
        <property name="title" translatable="yes">Default player</property>
        <child>
          <object class="AdwComboRow" id="combo_row_default_player">
            <property name="model">
              <object class="GListStore" id="list_store_default_player"/>
            </property>
            <property name="subtitle">Player to use</property>
            <property name="title" translatable="yes">Player</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup">
        <property name="title" translatable="yes">Players settings</property>
      </object>
    </child>
  </template>
</interface>
