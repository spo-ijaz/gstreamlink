<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.90.4 -->
<interface domain="org.gnome.gitlab.spoijaz.streamlinkgtk">
  <!-- interface-name preferences-interface.ui -->
  <requires lib="libadwaita" version="1.5"/>
  <template class="StreamlinkGtkPreferencesPageInterface" parent="AdwPreferencesPage">
    <property name="icon-name">preferences-system-symbolic</property>
    <property name="name">page_interface</property>
    <property name="title" translatable="yes">Interface</property>
    <child>
      <object class="AdwPreferencesGroup">
        <property name="title">Interface</property>
        <child>
          <object class="AdwSwitchRow" id="switch_row_minimize_gui">
            <property name="icon-name">zoom-out-symbolic</property>
            <property name="subtitle" translatable="yes">When a stream gets launched</property>
            <property name="title" translatable="yes">Minimize GUI</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup">
        <property name="title" translatable="yes">Notifications</property>
      </object>
    </child>
  </template>
</interface>
